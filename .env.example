# Copy to `.env` and adjust. Loaded at startup by the Electron main process.

# Where Agent Skills are stored and where "Add skill" installs to.
# Each skill is a sub-folder containing a SKILL.md.
# Defaults to ~/.file-browser-agent/skills when unset.


# Optional: provide the Anthropic API key via env instead of the in-app prompt.
# ANTHROPIC_API_KEY=sk-ant-...
